# Git Attributes — phenotype-hub
# Normalize line endings and improve diffs

*        text=auto eol=lf

# Markdown — treat as text
*.md     text diff=markdown

# YAML / YML
*.yml    text diff=yaml
*.yaml   text diff=yaml

# JSON
*.json   text diff=json

# Shell / scripts
*.sh     text eol=lf

# Binary — never diff
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    text diff=xml

# Linguist overrides
.gitattributes linguist-generated=false
