# =============================================================================
# Phenotype Hub — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
#
# All variables have defaults defined in .vitepress/config.mjs.
# Only override the ones you need to change.
# =============================================================================

# --- Site Metadata -----------------------------------------------------------
# The site title shown in the browser tab and header.
PH_SITE_TITLE="Phenotype Hub"

# The site description for SEO and meta tags.
PH_SITE_DESCRIPTION="Phenotype Hub documentation"

# Path to the favicon relative to the public directory.
PH_FAVICON_PATH="/favicon.ico"

# VitePress source directory (relative to repo root).
PH_SRC_DIR="docs"

# --- Social Links ------------------------------------------------------------
# GitHub repository URL for the social icon link.
PH_GITHUB_URL="https://github.com/KooshaPari/phenotype-hub"

# --- Navigation --------------------------------------------------------------
# JSON array of nav link objects: [{"text":"Home","link":"/"}, ...]
# Default: [{"text":"Home","link":"/"},{"text":"Journeys","link":"/journeys/"},{"text":"Operations","link":"/operations/"},{"text":"Worklogs","link":"/worklogs/"}]
PH_NAV_LINKS='[{"text":"Home","link":"/"},{"text":"Journeys","link":"/journeys/"},{"text":"Operations","link":"/operations/"},{"text":"Worklogs","link":"/worklogs/"}]'

# --- Build & Deployment ------------------------------------------------------
# Node.js version used in CI build steps.
PH_NODE_VERSION="20"

# GitHub Pages artifact retention period (days).
PH_ARTIFACT_RETENTION_DAYS="5"

# --- CI / GitHub Actions -----------------------------------------------------
# Cron schedule for scheduled workflows (standard cron syntax).
# CodeQL scan: weekly on Monday at 04:17 UTC
PH_CRON_CODEQL="17 4 * * 1"
# Scorecard scan: weekly on Saturday at 03:17 UTC
PH_CRON_SCORECARD="17 3 * * 6"
# Secrets scan: daily at 06:00 UTC
PH_CRON_SECRETS="0 6 * * *"

# --- Scorecard ---------------------------------------------------------------
# OpenSSF Scorecard action version.
PH_SCORECARD_ACTION_VERSION="v2.4.3"

# --- Pre-commit --------------------------------------------------------------
# Pre-commit hook version for conventional commit enforcement.
PH_CONVENTIONAL_COMMIT_VERSION="v4.0.0"

# Maximum file size (KB) that pre-commit will allow.
PH_MAX_FILE_SIZE_KB="500"
